@page "/shipping-process/{OrderId:int}"
@using System.Globalization
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.QuickGrid
@using AdventureWorksDominicana.Data.Models
@inject AdventureWorksDominicana.Services.ShippingService ShippingService
@inject BlazorBootstrap.ToastService ToastService
@inject NavigationManager Navigation

<div class="card shadow-lg">
    <div class="card-header">
        <h4 class="mb-0">@Titulo</h4>
    </div>

    <div class="card-body">
        @if (order == null)
        {
            <div class="alert alert-warning mb-0">
                No se encontró la orden.
            </div>
        }
        else
        {
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="mb-3">
                        <strong>Orden</strong>
                        <div>@order.SalesOrderId</div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-3">
                        <strong>Cliente</strong>
                        <div>@GetCustomerName(order)</div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-3">
                        <strong>Fecha de orden</strong>
                        <div>@order.OrderDate.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="mb-3">
                        <strong>Dirección de envío</strong>
                        <div>@GetAddressText(order)</div>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <QuickGrid Items="@(details.AsQueryable())" class="table table-striped table-bordered table-hover">
                    <PropertyColumn Property="d => d.SalesOrderDetailId" Title="Detalle" />
                    <PropertyColumn Property="d => d.ProductId" Title="Producto" />
                    <PropertyColumn Property="d => d.OrderQty" Title="Cantidad" />
                    <PropertyColumn Property="d => d.UnitPrice" Title="Precio" />
                    <PropertyColumn Property="d => d.LineTotal" Title="Subtotal" />
                </QuickGrid>
            </div>

            <EditForm Model="form" OnValidSubmit="GuardarAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Método de envío</label>
                            <InputSelect class="form-select" @bind-Value="form.ShipMethodId">
                                <option value="0">Seleccione...</option>
                                @foreach (var item in shipMethods)
                                {
                                    <option value="@item.ShipMethodId">@item.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => form.ShipMethodId)" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Comentario</label>
                            <InputText class="form-control" @bind-Value="form.Comment" />
                            <ValidationMessage For="@(() => form.Comment)" />
                        </div>
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <strong>Subtotal</strong>
                            <div>@subtotal.ToString("C2", CultureInfo.GetCultureInfo("es-DO"))</div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <strong>Flete</strong>
                            <div>@freight.ToString("C2", CultureInfo.GetCultureInfo("es-DO"))</div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <strong>Total</strong>
                            <div>@totalDue.ToString("C2", CultureInfo.GetCultureInfo("es-DO"))</div>
                        </div>
                    </div>
                </div>

                <div class="card-footer text-center mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-floppy"></i> @BotonGuardar
                    </button>

                    <button type="button" class="btn btn-secondary ms-2" @onclick="Volver">
                        Volver
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter] public int OrderId { get; set; }

    private SalesOrderHeader? order;
    private List<SalesOrderDetail> details = new();
    private List<ShipMethod> shipMethods = new();

    private ShippingFormModel form = new();
    private decimal subtotal;
    private decimal freight;
    private decimal totalDue;

    private string Titulo => order == null
        ? "Procesar envío"
        : order.Status == 5
            ? "Editar envío"
            : "Procesar envío";

    private string BotonGuardar => order?.Status == 5 ? "Actualizar envío" : "Confirmar envío";

    protected override async Task OnParametersSetAsync()
    {
        order = await ShippingService.GetOrderAsync(OrderId);
        shipMethods = await ShippingService.GetShipMethodsAsync();

        if (order != null)
        {
            details = order.SalesOrderDetails
                .OrderBy(x => x.SalesOrderDetailId)
                .ToList();

            subtotal = details.Sum(x => x.LineTotal);
            freight = order.Freight;
            totalDue = order.TotalDue;

            form.ShipMethodId = order.ShipMethodId;
            form.Comment = order.Comment;
        }
    }

    private async Task GuardarAsync()
    {
        try
        {
            if (form.ShipMethodId <= 0)
            {
                ToastService.ShowError("Seleccione un método de envío.");
                return;
            }

            if (order == null)
            {
                ToastService.ShowError("La orden no fue encontrada.");
                return;
            }

            if (order.Status == 5)
            {
                await ShippingService.UpdateShipmentAsync(order.SalesOrderId, form.ShipMethodId, form.Comment);
                ToastService.ShowSuccess(ConstruirMensaje("Se actualizó el envío"));
            }
            else
            {
                await ShippingService.ConfirmShipmentAsync(order.SalesOrderId, form.ShipMethodId);
                ToastService.ShowSuccess(ConstruirMensaje("Se creó el envío"));
            }

            Navigation.NavigateTo("/shipping-orders");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private void Volver()
    {
        Navigation.NavigateTo("/shipping-orders");
    }

    private string ConstruirMensaje(string texto)
    {
        var ahora = ObtenerHoraRepublicaDominicana();
        return $"{texto} — {ahora:dd/MM/yyyy hh:mm tt}";
    }

    private static DateTime ObtenerHoraRepublicaDominicana()
    {
        var timeZoneIds = new[] { "SA Western Standard Time", "America/Santo_Domingo" };

        foreach (var id in timeZoneIds)
        {
            try
            {
                var zone = TimeZoneInfo.FindSystemTimeZoneById(id);
                return TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, zone);
            }
            catch
            {
            }
        }

        return DateTime.Now;
    }

    private static string GetCustomerName(SalesOrderHeader order)
    {
        var personName = order.Customer?.Person != null
            ? $"{order.Customer.Person.FirstName} {order.Customer.Person.LastName}".Trim()
            : string.Empty;

        if (!string.IsNullOrWhiteSpace(personName))
        {
            return personName;
        }

        return order.Customer?.Store?.Name ?? "N/A";
    }

    private static string GetAddressText(SalesOrderHeader order)
    {
        var address = order.ShipToAddress;

        if (address == null)
        {
            return "N/A";
        }

        return $"{address.AddressLine1}, {address.City}, {address.StateProvinceId}";
    }

    private sealed class ShippingFormModel
    {
        [Range(1, int.MaxValue, ErrorMessage = "Debe seleccionar un método de envío.")]
        public int ShipMethodId { get; set; }

        [StringLength(250, ErrorMessage = "El comentario no puede superar 250 caracteres.")]
        public string? Comment { get; set; }
    }
}