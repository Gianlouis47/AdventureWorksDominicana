@page "/Department/Index"
@rendermode InteractiveServer
@inject DepartmentService departmentService

<PageTitle>Department Index</PageTitle>

<div class="container">
    <div class="card shadow-lg">
        @*Header*@
        <div class="card-header d-flex justify-content-between">
            <h5 class="card-title">Registro de Departamentos</h5>
            <a href="Department/Create" class="btn btn-outline-primary d-flex gap-2">
                <i class="bi bi-plus-square-fill"></i>
                <span>Crear</span>
            </a>
        </div>
        
        <div class="card-body">
            @*Filters*@
            <div class="row">
                <div class="col-6">
                    <label class="form-label">Desde</label>
                    <input class="form-control" type="date" />
                </div>
                <div class="col-6">
                    <label class="form-label">Hasta</label>
                    <input class="form-control" type="date" />
                </div>
            </div>
            <div class="row">
                <div class="col-6">
                    <label class="form-label">Seleccione una opci&oacute;n</label>
                    <select class="form-select">
                        <option value="0">Seleccione una opci&oacute;n</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label">Buscar</label>
                    <div class="input-group">
                        <input class="form-control" type="text" placeholder="Buscar"/>
                        <i class="btn btn-outline-primary bi bi-search"></i>
                    </div>
                </div>
            </div>
            @*Table*@
            <div class="table-responsive mt-3">
                <QuickGrid Items="DepartmentsList.AsQueryable()" Pagination="@pages" Class="table table-bordered table-hover">
                    <PropertyColumn Property="@(d => d.DepartmentId)" Title="DepartamentoId" Sortable="true" />
                    <PropertyColumn Property="@(d => d.Name)" Title="Nombre" Sortable="true" />
                    <PropertyColumn Property="@(d => d.GroupName)" Title="Nombre del Grupo" Sortable="true" />
                    <TemplateColumn Context="option" Title="Opci&oacute;n">
                        <a href="Department/Edit/@option.DepartmentId" class="btn btn-outline-primary bi bi-edit"></a>
                    </TemplateColumn>
                </QuickGrid>
                @*Pagination*@
                <Paginator State="@pages"/>
            </div>
        </div>
    </div>
</div>
@code {
    private List<Department> DepartmentsList = new List<Department>();
    private PaginationState pages = new PaginationState{ ItemsPerPage = 5 };
}
